# Environment Variables for Real-Time Object Detection System
# Internship ID: CITS2432

# YOLOv8 Model Configuration
YOLO_MODEL_PATH=models/
YOLO_MODEL=yolov8n.pt
YOLO_DEVICE=cpu
# For GPU use: YOLO_DEVICE=cuda
# For specific GPU: YOLO_DEVICE=cuda:0

# Detection Parameters
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45
MAX_DETECTIONS=300

# Output Directories
OUTPUT_DIR=outputs/
DATA_DIR=data/
LOG_DIR=logs/

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/detection.log

# Analytics Configuration
ENABLE_ANALYTICS=true
EXPORT_CSV=true
EXPORT_JSON=true

# Performance Settings
BATCH_SIZE=1
NUM_WORKERS=0
PIN_MEMORY=false

# Streamlit Configuration
STREAMLIT_THEME=dark
STREAMLIT_LOGGER_LEVEL=info

# Image Processing
IMAGE_MAX_WIDTH=1280
IMAGE_MAX_HEIGHT=720
SAVE_ANNOTATED_IMAGES=true

# Video Processing
VIDEO_MAX_WIDTH=1280
VIDEO_MAX_HEIGHT=720
SAVE_PROCESSED_VIDEOS=true
VIDEO_CODEC=mp4v

# Debug Mode
DEBUG=false
VERBOSE=false

# Optional: GPU Memory Configuration
# GPU_MEMORY_FRACTION=0.8  # Use 80% of GPU memory
